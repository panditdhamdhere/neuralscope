# ── Server ──────────────────────────────────────────────
DATABASE_URL=postgres://neuralscope:neuralscope@localhost:5432/neuralscope
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# Host port when running `docker compose` (change if 8080 is taken)
SERVER_HOST_PORT=8080
APP_ENV=development
RUN_MIGRATIONS=true
RUST_LOG=neuralscope=debug,tower_http=debug,sqlx=warn

# Comma-separated browser origins allowed to call the API (required in staging/production)
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=30

# ── AI Providers ────────────────────────────────────────
AI_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# MCP server (stdio — for Cursor / Claude Desktop)
NEURALSCOPE_PROJECT_ID=

# Embeddings
JINA_API_KEY=
NOMIC_EMBED_URL=http://localhost:8081

# ── Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Set to true only when SMTP/email verification is configured
# REQUIRE_EMAIL_VERIFICATION=true

# ── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web app uses DATABASE_URL for Better Auth (same Postgres as server)

# ── Production (see docs/DEPLOYMENT.md) ───────────────────
# APP_ENV=production
# RUN_MIGRATIONS=false
# BETTER_AUTH_SECRET=<openssl rand -base64 32>
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
# BETTER_AUTH_URL=https://app.yourdomain.com
# NEXT_PUBLIC_API_URL=https://app.yourdomain.com
# NEXT_PUBLIC_WS_URL=wss://app.yourdomain.com/ws
# NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# ── Production checklist ──────────────────────────────────
# APP_ENV=production
# RUN_MIGRATIONS=false          # use `neuralscope-server --migrate-only` or K8s Job
# BETTER_AUTH_SECRET=<32+ chars, not a placeholder>
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
# BETTER_AUTH_URL=https://app.yourdomain.com
# NEXT_PUBLIC_*=https URLs matching your ingress
