# Copy to secret.yaml and fill with production values.
# Do not commit real secrets to version control.
apiVersion: v1
kind: Secret
metadata:
  name: neuralscope-secrets
  namespace: neuralscope
type: Opaque
stringData:
  DATABASE_URL: postgres://USER:PASSWORD@HOST:5432/neuralscope
  REDIS_URL: redis://HOST:6379
  BETTER_AUTH_SECRET: replace-with-openssl-rand-base64-32
  GROQ_API_KEY: ""
  AI_DEFAULT_PROVIDER: "groq"
